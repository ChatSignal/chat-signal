{
  "manifest_version": 3,
  "name": "Chat Signal",
  "version": "2.0.0",
  "description": "AI-powered live chat intelligence for YouTube and Twitch. Clusters messages, tracks sentiment and trending topics. 100% local.",
  "homepage_url": "https://chatsignal.dev",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.twitch.tv/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.twitch.tv/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "action": {
    "default_title": "Open Chat Signal",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src https://huggingface.co https://cdn-lfs.huggingface.co https://*.xethub.hf.co https://raw.githubusercontent.com;"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "libs/transformers/transformers.js",
        "libs/transformers/*.wasm",
        "libs/transformers/*.mjs"
      ],
      "matches": ["https://www.youtube.com/*", "https://www.twitch.tv/*"]
    },
    {
      "resources": [
        "wasm/wasm_engine_bg.wasm",
        "wasm/wasm_engine.js"
      ],
      "matches": ["https://www.youtube.com/*", "https://www.twitch.tv/*"]
    }
  ]
}
